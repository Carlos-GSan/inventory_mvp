# =============================================================================
# CONFIGURACIÓN GENERAL DE DJANGO
# =============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
# Genera una nueva clave con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-me-in-production

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# Hosts permitidos (separados por coma). Ejemplo: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# URL del sitio (sin / al final)
SITE_URL=http://localhost:8000


# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Para usar PostgreSQL en lugar de SQLite
USE_POSTGRES=True

# Configuración de PostgreSQL
POSTGRES_DB=disitech_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432


# =============================================================================
# CONFIGURACIÓN DE SUPERUSUARIO
# =============================================================================

# Credenciales del superusuario que se creará automáticamente en el primer inicio
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123


# =============================================================================
# CONFIGURACIÓN DE BUNNY STORAGE (CDN)
# =============================================================================

# Activar Bunny Storage para archivos media
USE_BUNNY_STORAGE=False

# Credenciales de Bunny.net Storage (obtener desde https://panel.bunny.net/)
BUNNY_USERNAME=
BUNNY_PASSWORD=
BUNNY_TOKEN_KEY=
BUNNY_REGION=la
MEDIA_URL=https://tu-pullzone.b-cdn.net/


# =============================================================================
# CONFIGURACIÓN DE EMAIL
# =============================================================================

# Backend de email (console para desarrollo, smtp para producción)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Configuración SMTP (Gmail, SendGrid, Mailgun, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-o-app-password
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True

# Emails por defecto
DEFAULT_FROM_EMAIL=no-reply@example.com
SUPPORT_INBOX=soporte@example.com


# =============================================================================
# CONFIGURACIÓN DE DOCKER (Opcional)
# =============================================================================

# Puerto en el que se expondrá la aplicación
WEB_PORT=8000
